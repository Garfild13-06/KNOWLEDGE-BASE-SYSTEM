# Скопируйте в backend/.env и при необходимости в корень для docker compose

# PostgreSQL (docker compose подставляет значения по умолчанию)
POSTGRES_USER=kb_admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=knowledge_base

# TinyMCE (опционально)
# VITE_TINYMCE_API_KEY=

# Возможности базы знаний (по умолчанию выключены тяжёлые функции)
KB_ENABLE_AI=false
KB_ENABLE_SEMANTIC_SEARCH=false
KB_ENABLE_GAMIFICATION=false
KB_ENABLE_GRAPH_VIEW=true
KB_ENABLE_PUBLIC_PORTAL=true
KB_SANDBOX_TTL_HOURS=72

# OpenAI — только если KB_ENABLE_AI=true
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
