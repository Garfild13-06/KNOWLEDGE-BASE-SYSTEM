# Шаблон для scripts/run-lan-test.sh (генерируется автоматически в backend/.env.lan)
# Режим только для локальной сети — не для production.

SECRET_KEY=lan-test-insecure-key-do-not-use-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

DB_ENGINE=django.db.backends.postgresql
DB_NAME=knowledge_base
DB_USER=kb_admin
DB_PASSWORD=lan_test_db
DB_HOST=db
DB_PORT=5432

# Без ограничений CORS (любой origin в LAN)
CORS_ALLOW_ALL_ORIGINS=True

POSTGRES_USER=kb_admin
POSTGRES_PASSWORD=lan_test_db
POSTGRES_DB=knowledge_base
