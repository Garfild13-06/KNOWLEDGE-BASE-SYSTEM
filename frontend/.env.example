# Пустая строка — запросы на тот же origin (Docker/nginx). Для Vite dev оставьте пустым и используйте proxy в vite.config.js
VITE_API_URL=

# TinyMCE поставляется как self-hosted пакет (npm i tinymce), API-ключ от TinyMCE Cloud НЕ требуется.
# Переменная оставлена для обратной совместимости, по умолчанию её можно не задавать.
# VITE_TINYMCE_API_KEY=
